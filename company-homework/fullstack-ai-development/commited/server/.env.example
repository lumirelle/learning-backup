APP_ENV=dev
# 本地开发端口：与前端 dev 代理（web nitro.devProxy → :8090）保持一致。
APP_PORT=8090
DATABASE_URL=postgres://orghr:orghr@localhost:5433/orghr?sslmode=disable
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_HOURS=24
REDIS_URL=redis://localhost:6380

# SSO：PROJECT_ID 与 API_SECRET 均配置后才启用；默认不启用。
# API_SECRET 在 SSO 项目「认证配置 → 签名秘钥」生成；请勿提交真实秘钥。
SSO_BASE_URL=https://sso.example.com
SSO_PROJECT_ID=
SSO_API_SECRET=
# SSO 验证通过但本地无账号时是否自动开通最小权限账号（默认 false：仅放行已有账号）
SSO_AUTO_PROVISION=false

# LDAP：把组织架构同步进本系统（LDAP 为唯一事实源）。
# URL/BIND_DN/BIND_PW 均配置后才启用。注意：LDAP:389 侧有来源 IP 白名单，
# 同步须在公司内网（白名单内）运行；BIND_PW 敏感，勿提交真实值。
LDAP_URL=ldap://sso.example.com:389
LDAP_BASE_DN=...
LDAP_USER_DN=...
LDAP_GROUP_DN=...
LDAP_BIND_DN=...
LDAP_BIND_PW=...
LDAP_START_TLS=false
# 定时同步间隔（Go duration，如 6h）。留空 = 关闭，仅超管手动同步。
LDAP_SYNC_INTERVAL=
