# ─────────────────────────────────────────────────────────────
#  ATS Backend env · 复制为 ats-backend/.env 后按需覆盖
#  application.yml 的 `spring.config.import` 会自动加载
#  dev 默认值已 OK，本文件只是给运维/CI 一个完整变量清单
# ─────────────────────────────────────────────────────────────

# ── DB / Redis ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ats_db
DB_USER=ats_user
DB_PASSWORD=ats_pwd

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── 服务端口 ─────────────────────────────────────
SERVER_PORT=8080

# ── JWT RS256 ────────────────────────────────────
# 路径基准 = backend 启动 cwd；dev 默认 ../infra/jwt（解析为仓库根下 infra/jwt）
# 生产把 keypair 挂到 /etc/ats/jwt 后改为：
#   ATS_JWT_KEY_DIR=/etc/ats/jwt
#   JWT_PRIVATE_KEY_FILE=private.pem
#   JWT_PUBLIC_KEY_FILE=public.pem
ATS_JWT_KEY_DIR=../infra/jwt
JWT_PRIVATE_KEY_FILE=dev-private.pem
JWT_PUBLIC_KEY_FILE=dev-public.pem

# token 寿命（秒）—— access 短 / refresh 长是核心安全模式
# ⚠️ .env 不支持行内 # 注释（会被当成 value 一部分），数值后必须直接换行
# access = 900s (15 min)
JWT_ACCESS_TTL_SECONDS=900
# refresh = 2592000s (30 day)
JWT_REFRESH_TTL_SECONDS=2592000
JWT_ISSUER=ats.local

# refresh cookie 配置
# 生产 HTTPS 部署必须改：SAMESITE=None 且 SECURE=true，否则浏览器拒收
JWT_REFRESH_COOKIE_SAMESITE=Lax
JWT_REFRESH_COOKIE_SECURE=false
JWT_REFRESH_COOKIE_DOMAIN=

# ── 文件上传 ─────────────────────────────────────
UPLOAD_PATH=./uploads
UPLOAD_MAX_FILE_MB=5
