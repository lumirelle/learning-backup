# ─────────────────────────────────────────────────────────────
#  ATS 开发环境变量 · 复制为 infra/.env 后填入实际值
#  compose 会自动加载同目录下的 .env
# ─────────────────────────────────────────────────────────────

# Postgres
POSTGRES_DB=ats_db
POSTGRES_USER=ats_user
POSTGRES_PASSWORD=ats_pwd
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
