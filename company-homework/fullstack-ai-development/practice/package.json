{
  "name": "demo-homework",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "docs:project-selection-analysis": "bun run docs/project-selection-analysis.html",
    "docs:project-requirements": "PORT=3001 bun run docs/project-requirements.html",
    "docs:project-tech-design": "PORT=3002 bun run docs/project-tech-design.html",
    "docs:project-dev-plan": "PORT=3003 bun run docs/project-dev-plan.html",
    "docs:project-milestones": "PORT=3004 bun run docs/project-milestones.html",
    "check-env": "pwsh -File scripts/check-env.ps1",
    "dev:up": "docker-compose -f infra/docker-compose.dev.yml --env-file infra/.env up -d",
    "dev:down": "docker-compose -f infra/docker-compose.dev.yml --env-file infra/.env down",
    "dev:reset": "docker-compose -f infra/docker-compose.dev.yml --env-file infra/.env down -v",
    "dev:logs": "docker-compose -f infra/docker-compose.dev.yml --env-file infra/.env logs -f",
    "dev:ps": "docker-compose -f infra/docker-compose.dev.yml ps",
    "infra:up": "podman compose -f infra/docker-compose.dev.yml up -d",
    "infra:down": "podman compose -f infra/docker-compose.dev.yml down",
    "infra:reset": "podman compose -f infra/docker-compose.dev.yml down -v && podman compose -f infra/docker-compose.dev.yml up -d",
    "infra:logs": "podman compose -f infra/docker-compose.dev.yml logs -f",
    "infra:ps": "podman compose -f infra/docker-compose.dev.yml ps",
    "prod:build": "docker-compose -f infra/docker-compose.prod.yml --env-file infra/.env.prod build",
    "prod:up": "docker-compose -f infra/docker-compose.prod.yml --env-file infra/.env.prod up -d",
    "prod:down": "docker-compose -f infra/docker-compose.prod.yml --env-file infra/.env.prod down",
    "prod:reset": "docker-compose -f infra/docker-compose.prod.yml --env-file infra/.env.prod down -v",
    "prod:logs": "docker-compose -f infra/docker-compose.prod.yml --env-file infra/.env.prod logs -f",
    "prod:ps": "docker-compose -f infra/docker-compose.prod.yml ps",
    "prod:release": "pwsh -File infra/scripts/release.ps1",
    "prod:release:bash": "bash infra/scripts/release.sh",
    "be:dev": "cd ats-backend && mvn spring-boot:run",
    "be:test": "cd ats-backend && mvn -B test",
    "be:test:fast": "cd ats-backend && mvn -B -q test",
    "be:build": "cd ats-backend && mvn -B package -DskipTests",
    "be:verify": "cd ats-backend && mvn -B verify",
    "fe:dev": "cd ats-frontend && bun run dev",
    "fe:build": "cd ats-frontend && bun run build",
    "fe:typecheck": "cd ats-frontend && bun run typecheck",
    "fe:lint": "cd ats-frontend && bun run lint",
    "fe:lint:fix": "cd ats-frontend && bun run lint:fix",
    "fe:check": "cd ats-frontend && bun run typecheck && bun run lint",
    "fe:e2e": "cd ats-frontend && bun run e2e",
    "lint": "oxlint && eslint .",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "lint:oxlint": "oxlint",
    "lint:eslint": "eslint ."
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@lumirelle/oxlint-config": "^0.6.0",
    "@lumirelle/tsconfig": "^0.1.4",
    "bun-types": "^1.3.14",
    "cursor": "^0.1.5",
    "eslint": "^10.4.0",
    "eslint-plugin-oxlint": "^1.66.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  }
}
